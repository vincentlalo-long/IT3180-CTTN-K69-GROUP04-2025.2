# ============================================
# MIXIFOOT Backend — Environment Variables Template
# ============================================
# Copy file này thành .env và điền giá trị thật:
#   cp .env.example .env

# === Database ===
DB_PASSWORD=your_db_password

# === JWT ===
JWT_SECRET=your_jwt_secret_hex_key

# === Google OAuth ===
GOOGLE_CLIENT_ID=your_google_client_id

# === VNPay Sandbox ===
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret

# === Spring Boot SQL Init Mode ===
# Set to 'always' to reset and seed the database. Set to 'never' to preserve data across restarts.
SPRING_SQL_INIT_MODE=always

